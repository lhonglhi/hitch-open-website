# ==================== Cache Control ====================

# HTML - never cache, always fetch latest
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# JSON data - never cache
<FilesMatch "\.json$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# CSS & JS - cache 1 year (safe because filenames include ?v=xxx version param)
<FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Images & video - cache 30 days
<FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico|mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# ==================== Enable mod_headers ====================
<IfModule mod_headers.c>
    # Already handled above
</IfModule>
